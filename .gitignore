# Project-root ignores. Per-tree ignores live alongside the tree
# (rust/.gitignore for the cargo target dir, python/.gitignore for
# venv + caches).

# Scratch / temporary working dir for one-off dumps, notes, traces.
tmp/

# macOS junk.
.DS_Store

# Kernel workdir state — created when running fantastic from the
# repo root for dev/testing. Per-tree clones live under rust/ and
# python/ but the root convenience here gets its own ignore.
.fantastic/

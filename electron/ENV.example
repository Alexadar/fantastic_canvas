# Fantastic Canvas — macOS signing environment variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Option A: Direct credentials
APPLE_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_ID=your@email.com
APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=YOURTEAMID

# Option B: Keychain profile (preferred for local dev)
# Run: xcrun notarytool store-credentials "fantastic-canvas" ...
# KEYCHAIN_PROFILE=fantastic-canvas

# Optional: explicit Python path
# FANTASTIC_PYTHON=/opt/homebrew/bin/python3.12

# Optional: project directory override
# FANTASTIC_PROJECT_DIR=/path/to/your/project

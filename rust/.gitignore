target/
**/*.rs.bk
*.pdb
# Cargo.lock IS committed — fantastic-cli is a binary crate, so a
# reproducible lockfile is part of the artifact contract.

# Runtime state — tests that drive the CLI may leak this if
# they forget to use a tempdir for their workdir.
.fantastic/

# Swift Package build artifacts — built fresh by the variant scripts
# under `scripts/build-xcframework{,-embedded,-full}.sh`. Not committed:
# each .a slice is 40-80 MB, the multi-slice XCFrameworks total 80-
# 160 MB which is over GitHub's 100 MB single-file limit. Operators
# build locally OR pull from a tagged GH Release.
#
# Two SPM-package variants today (`FantasticKernelEmbedded` for iOS
# Lite, `FantasticKernelFull` for Pro Mac); the glob covers any
# `FantasticKernel*` variant a future split adds.

# Built XCFrameworks (per variant). Pattern matches:
#   Fantastic.xcframework               (old single-variant layout)
#   Fantastic-Embedded.xcframework      (current iOS-safe tier)
#   Fantastic-Full.xcframework          (current desktop/PTY tier)
packaging/FantasticKernel*/Fantastic*.xcframework/

# SPM build cache + IDE state.
packaging/FantasticKernel*/.build/
packaging/FantasticKernel*/.swiftpm/

# UniFFI auto-generates `fantastic.swift` from the UDL at xcframework
# build time. Build product, not source. The hand-written
# `FantasticKernel.swift` wrapper IS committed.
packaging/FantasticKernel*/Sources/*/fantastic.swift
